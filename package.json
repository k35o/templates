{
  "name": "@k8o/create",
  "version": "0.2.5",
  "description": "k8o's Vite+ project generator — run `vp create @k8o`.",
  "keywords": [
    "bingo-template",
    "create",
    "k8o",
    "template",
    "vite-plus-generator"
  ],
  "homepage": "https://github.com/k35o/templates#readme",
  "bugs": "https://github.com/k35o/templates/issues",
  "license": "MIT",
  "author": "k8o (https://github.com/k35o)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/templates.git"
  },
  "bin": "./dist/index.mjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "dev": "node bin/index.ts",
    "check": "vp check",
    "check:write": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "ready": "vp fmt && vp lint && vp test"
  },
  "dependencies": {
    "bingo": "0.7.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@k8o/oxc-config": "0.1.3",
    "@types/node": "24.13.1",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.15.1"
}
