{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>k35o/renovate-config"],
  "mise": {
    "enabled": true,
    "managerFilePatterns": ["/^mise\\.toml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^src/versions\\.ts$/"],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+[\\w'@/.-]+:\\s*'(?<currentValue>[^']+)'"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchPackageNames": ["bingo", "zod"],
      "groupName": "bingo dependencies"
    },
    {
      "matchPackageNames": ["/^@changesets/"],
      "groupName": "changesets dependencies"
    },
    {
      "matchPackageNames": ["/^pnpm$/"],
      "groupName": "pnpm dependencies"
    },
    {
      "matchPackageNames": ["/^node$/"],
      "groupName": "node dependencies"
    },
    {
      "matchPackageNames": ["changesets/action"],
      "enabled": false
    }
  ]
}
