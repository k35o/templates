{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>k35o/renovate-config"],
  "gitIgnoredAuthors": ["268958302+k8o-bot[bot]@users.noreply.github.com"],
  "mise": {
    "enabled": true,
    "managerFilePatterns": ["/^mise\\.toml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^src/versions\\.ts$/"],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+[\\w'@/.-]+:\\s*'(?<currentValue>[^']+)'"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchPackageNames": ["bingo", "zod"],
      "groupName": "bingo dependencies"
    },
    {
      "description": "Pin bingo to 0.7.x: 0.8+/0.9 break the createTemplate/CLI API we rely on.",
      "matchPackageNames": ["bingo"],
      "allowedVersions": "<0.8.0"
    },
    {
      "description": "Pin zod to 3.x: bingo 0.7 requires zod ^3 and reads zod-3 schema internals.",
      "matchPackageNames": ["zod"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchPackageNames": ["/^pnpm$/"],
      "groupName": "pnpm dependencies"
    },
    {
      "matchPackageNames": ["/^node$/"],
      "groupName": "node dependencies"
    }
  ]
}
